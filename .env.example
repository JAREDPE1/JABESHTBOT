# Carpeta persistente para configuracion y estado
DATA_DIR=./data

# Carpeta de sesion de WhatsApp
AUTH_DIR=./data/sesion

# Carpeta temporal
TMP_DIR=./tmp

# Rutas opcionales si el sistema no encuentra estos comandos
YT_DLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg

# Solo necesario en Render/servicios web
PORT=3000

# Opcional: API autorizada para consultar DNI
# Puedes usar {dni} como marcador dentro de la URL.
DNI_API_URL=https://api.verificape.com/v2/dni/{dni}
DNI_API_TOKEN=

# Proveedor de IA: gemini u openai
AI_PROVIDER=gemini

# Gemini para comandos de IA
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_MS=90000

# OpenAI para comandos de IA
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=90000

# Limites de salida para cualquier proveedor
IA_MAX_TOKENS=1200
DOC_MAX_TOKENS=4200
